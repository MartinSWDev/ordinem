# Ordinem orchestrator — configuration.
# Copy to `.env` and fill in. Nothing here is hardcoded in the app.

# --- Database ---
# Points at whichever Postgres holds THIS deployment's data:
#   - work Mac:    a LOCAL Postgres for the `work` schema, so work Jira ticket
#                  details never leave the work machine (see README).
#   - home server: the shared Coolify Postgres for personal/shared data.
# Local dev default matches the docker command in the README.
DATABASE_URL=postgresql://ordinem:ordinem@localhost:5433/ordinem
DB_SCHEMA=work

# --- Jira ---
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=
# Custom field ID for "acceptance criteria" on your Jira instance, if used.
# Find via: GET /rest/api/3/field  (look for the field, note its "id", e.g. customfield_10034)
JIRA_ACCEPTANCE_CRITERIA_FIELD=

# --- Anthropic ---
# Used by the ticket planner AND the pre-PR reviewer (direct API calls).
# Agent dispatch does NOT use this key — it goes through the logged-in CLIs
# below. ANTHROPIC_BASE_URL overrides the endpoint (blank = default).
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
# Model used for the pre-PR reviewer.
REVIEW_MODEL=claude-opus-4-8

# --- Agent dispatch backends ---
# Mini-tickets run through a logged-in agent CLI — one-time setup per machine:
#   claude: npm i -g @anthropic-ai/claude-code, then run `claude` once to log
#           in with your Claude subscription.
#   cursor: curl https://cursor.com/install -fsS | bash, then `cursor-agent login`.
#   local:  point LOCAL_PROXY_URL at an Anthropic-compatible proxy (LiteLLM)
#           in front of your local model; shown as available while it responds.
# Override the binary names/paths if they aren't on the server's PATH.
CLAUDE_CLI=claude
CURSOR_CLI=cursor-agent
# Claude CLI --permission-mode for agent runs. Headless agents can't answer
# prompts and need to run tests + commit in their isolated worktree, so
# unattended is the default; acceptEdits restricts them to file edits only.
AGENT_PERMISSION_MODE=bypassPermissions
# cursor-agent can't prompt headlessly; --force lets it run commands. false = edit-only.
CURSOR_FORCE=true
AGENT_TIMEOUT_SECONDS=3600
LOCAL_PROXY_URL=

# --- Qwen fallback (LiteLLM proxy over Tailscale) ---
# Used by the planner/reviewer as the LLM fallback if Claude fails, and as the
# legacy name for LOCAL_PROXY_URL (needs an Anthropic-compatible proxy).
QWEN_PROXY_URL=

# Where your local checkouts live. Repos are auto-created from tickets (one per
# Jira project) and their checkout is guessed as <REPOS_BASE_DIR>/<name>; the
# ticket's repo picker lists git repos found here when the guess doesn't match.
REPOS_BASE_DIR=~/Repos

# --- Server ---
HOST=127.0.0.1
PORT=8787
# --- Calendar ---
# Option A: one or more private, read-only iCal feed URLs, comma-separated
# (Google Calendar's "Secret address in iCal format").
CALENDAR_ICS_URLS=

# Option B: Google Calendar via OAuth (read-only) — for calendars whose secret
# iCal address is disabled. Create a "Web application" OAuth client in the
# Google Cloud Console with redirect URI http://127.0.0.1:8787/calendar/oauth/callback
# and the calendar.readonly scope. When configured AND connected this takes
# precedence over CALENDAR_ICS_URLS. Connect once at /calendar/oauth/start.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/calendar/oauth/callback
# Which calendars to pull, comma-separated ids ("primary" = your main one; a
# secondary calendar's id is on its settings page, usually an @group...calendar.google.com address).
GOOGLE_CALENDAR_IDS=primary

# --- Todoist ---
# Personal API token used server-side for the read-only Todos island.
TODOIST_API_TOKEN=
