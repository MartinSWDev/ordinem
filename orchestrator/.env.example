# Ordinem orchestrator — configuration.
# Copy to `.env` and fill in. Nothing here is hardcoded in the app.

# --- Database ---
# Points at whichever Postgres holds THIS deployment's data:
#   - work Mac:    a LOCAL Postgres for the `work` schema, so work Jira ticket
#                  details never leave the work machine (see README).
#   - home server: the shared Coolify Postgres for personal/shared data.
# Local dev default matches the docker command in the README.
DATABASE_URL=postgresql://ordinem:ordinem@localhost:5433/ordinem
DB_SCHEMA=work

# --- Jira ---
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=
# Custom field ID for "acceptance criteria" on your Jira instance, if used.
# Find via: GET /rest/api/3/field  (look for the field, note its "id", e.g. customfield_10034)
JIRA_ACCEPTANCE_CRITERIA_FIELD=

# --- Anthropic ---
# Used by the ticket Agent SDK AND the pre-PR reviewer. Leave ANTHROPIC_API_KEY
# unset to use a logged-in `ant auth login` / Claude subscription session; set
# it for API-key auth. ANTHROPIC_BASE_URL overrides the endpoint (blank = default).
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
# Model used for the pre-PR reviewer.
REVIEW_MODEL=claude-opus-4-8

# --- Qwen fallback (LiteLLM proxy over Tailscale) ---
# Used on a StopFailure (rate-limit / auth) event to re-dispatch a subtask, and
# as the reviewer fallback if Claude fails (needs an Anthropic-compatible proxy).
QWEN_PROXY_URL=

# --- Server ---
HOST=127.0.0.1
PORT=8787
